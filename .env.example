# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=signalmind
DB_USERNAME=signalmind
DB_PASSWORD=signalmind_dev

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_64_BYTE_BASE64_SECRET
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ── Angel One SmartAPI ───────────────────────────────────────────────────────
# Obtain from https://smartapi.angelbroking.com/
ANGELONE_API_KEY=
ANGELONE_CLIENT_ID=
ANGELONE_MPIN=
ANGELONE_TOTP_SECRET=
ANGELONE_FEED_URL=wss://smartapisocket.angelbroking.com/smart-stream

# ── ICICI Breeze API ─────────────────────────────────────────────────────────
# Obtain from https://api.icicidirect.com/
BREEZE_API_KEY=
BREEZE_API_SECRET=
BREEZE_SESSION_TOKEN=

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Application ──────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
